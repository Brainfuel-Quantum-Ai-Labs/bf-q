# Port (set automatically by Railway)
PORT=4000

# Supabase JWT secret (Project → Settings → API → JWT Settings)
SUPABASE_JWT_SECRET="your-jwt-secret"

# Supabase project URL (for admin user listing)
SUPABASE_URL="https://your-project.supabase.co"

# Supabase service-role key — keep secret, never expose client-side
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="https://www.bf-q.com,http://localhost:3000"
