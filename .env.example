# ──────────────────────────────────────────────────────────────────────────────
# Database — PostgreSQL 16
# Docker Compose default: postgresql://bfq:bfq_local_password@localhost:5432/bfq_db
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bfq:bfq_local_password@localhost:5432/bfq_db"
POSTGRES_USER="bfq"
POSTGRES_PASSWORD="bfq_local_password"
POSTGRES_DB="bfq_db"

# For Vercel Postgres (Storage): set DATABASE_URL to POSTGRES_PRISMA_URL value
# and DIRECT_URL to POSTGRES_URL_NON_POOLING value (required for migrations).
# DIRECT_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────────────────────────────────────
# Worker
# ──────────────────────────────────────────────────────────────────────────────
SANDBOX_RUNNER_URL="http://sandbox-runner:8080"
QUEUE_NAME="sandbox-jobs"
WORKER_CONCURRENCY="2"

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ──────────────────────────────────────────────────────────────────────────────
# LinkedIn OAuth
# ──────────────────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# ──────────────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BrainFuel Quantum AI Labs"
